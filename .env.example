# Upstash Redis (create a database at upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public site URL (used to build access links in emails)
NEXT_PUBLIC_SITE_URL=https://investors.malamalabs.com

# Admin dashboard key (generate: openssl rand -hex 24)
INVESTOR_ADMIN_KEY=

# Where new-request alerts are sent
INVESTOR_NOTIFY_TO=founders@malamalabs.com

# Your email sender webhook (Resend / Postmark / SES wrapper)
MAIL_WEBHOOK_URL=

# Private document store base (signed-URL blob endpoint).
# Gated files live here, NEVER under /public.
PRIVATE_DOC_BASE_URL=
